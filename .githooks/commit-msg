#!/bin/sh
# Local commit-msg hook: Conventional Commits (Chinese subject, min 10 chars).
msg_file="$1"
subject=$(sed -n '1p' "$msg_file" | sed 's/^[[:space:]]*//;s/[[:space:]]*$//')

# Allow merge/squash/revert/cherry-pick autogenerated subjects
case "$subject" in
  Merge\ *|Squash\ commit\ *|Revert\ *|fixup!\ *|squash!\ *)
    exit 0
    ;;
esac

if [ "$subject" = "1" ]; then
  echo "commit-msg: 禁止使用占位主题「1」" >&2
  exit 1
fi

if ! printf '%s' "$subject" | grep -Eq '^(feat|fix|docs|chore|refactor|test|ci)(\([^)]+\))?: .{10,}'; then
  echo "commit-msg: 主题须匹配 type(scope): 中文简述（≥10 字）" >&2
  echo "  示例: feat(studio): 添加创作简报大纲预览流" >&2
  exit 1
fi

exit 0
